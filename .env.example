# Hors Coolify (VPS nu). Sur Coolify, ces SERVICE_* sont générés automatiquement.
MYSQL_DATABASE=rtb_wp
SERVICE_USER_WORDPRESS=rtb
SERVICE_PASSWORD_WORDPRESS=change-me-strong
SERVICE_PASSWORD_MYSQLROOT=change-me-root-strong

# URL publique du site (Coolify la fournit ; en local, ex. http://localhost:8083)
SERVICE_URL_WORDPRESS=http://localhost:8083
SERVICE_FQDN_WORDPRESS_80=

# Récupération admin temporaire (≥24 caractères). Laisser vide = désactivé.
RTB_RECOVERY_TOKEN=
